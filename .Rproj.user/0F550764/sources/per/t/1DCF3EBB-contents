```{r}
set.seed(5286)
selected_barcodes=sample(unique(res$Sample_name),500)
```


```{r}

subset_df <- res %>%
   filter(Sample_name %in% selected_barcodes,
          Deconvolution_type != "MCPcounter",
          cell_type %in% c("B cell", "T cell"), # or loop through both cell types
          Gene_panel %in% c("WTA", "Targeted Immunology", "Targeted Pan Cancer")) %>%
   mutate(Deconvolution_type = ifelse(Deconvolution_type == "SpatialDecon \ndefault signature", 
                                      "SpatialDecon", Deconvolution_type)) %>%
   mutate(Gene_panel = factor(Gene_panel, levels = c("WTA", "Targeted Immunology", "Targeted Pan Cancer"))) %>% 
   mutate(Deconvolution_type=factor(Deconvolution_type, levels = c("quanTIseq","EPIC","SpatialDecon")))


 # Pivot to wide format for Friedman test
 friedman_input <- subset_df %>%
   select(Sample_name, Gene_panel, Deconvolution_proportions, cell_type) %>%
   pivot_wider(names_from = Gene_panel, values_from = Deconvolution_proportions)
 

methods <- levels(subset_df$Deconvolution_type)

all_p_values= data.frame()

# Loop through each Deconvolution_type
for (cell in c("B cell","T cell")) 
   {
       for (method in methods) {
       cat("\n---", method, "---\n")
       
       # Subset one method
       df_sub <- friedman_input %>%
         filter(cell_type==cell) %>% 
         filter(Deconvolution_type == method) %>%
         select(Sample_name, WTA, `Targeted Immunology`, `Targeted Pan Cancer`)
       
       # Friedman test
       friedman_res <- friedman.test(as.matrix(df_sub[,-1]))
       print(friedman_res)
       
       # Reshape to long for pairwise wilcox
       df_long <- df_sub %>%
         ungroup() %>% 
         select(1,3,4,5) %>% 
         pivot_longer(cols = -Deconvolution_type, names_to = "Panel", values_to = "Proportion")
       
       # Pairwise Wilcoxon signed-rank tests (with Bonferroni correction)
       pairwise_res <- df_long %>%
         pairwise_wilcox_test(
           Proportion ~ Panel,
           paired = TRUE,
           p.adjust.method = "bonferroni"
         )
       
       all_p_values=rbind(all_p_values,
                          pairwise_res %>% 
                          mutate("Deconvolution_tool"=method,
                                 "cell_type"=cell))
       }
 }

```

```{r}
plt=res %>% 
  dplyr::filter(Sample_name %in% selected_barcodes ) %>% 
  dplyr::filter(Deconvolution_type !="MCPcounter") %>% 
  dplyr::filter(cell_type %in% c("B cell","T cell") ) %>% 
  dplyr::mutate(Deconvolution_type=ifelse(Deconvolution_type=="SpatialDecon \ndefault signature","SpatialDecon",Deconvolution_type)) %>% 
  dplyr::mutate(Deconvolution_type=factor(Deconvolution_type,levels = c("quanTIseq","EPIC","SpatialDecon"))) %>% 
  dplyr::mutate(Gene_panel=factor(Gene_panel,levels=c("WTA","Targeted Immunology","Targeted Pan Cancer"))) %>% 
  ggplot(aes(x=Gene_panel,y=Deconvolution_proportions, color=Gene_panel, group=Sample_name))+
  geom_line(alpha = 0.2, show.legend = FALSE)+
  geom_point()+
  facet_grid(cell_type~Deconvolution_type,axes="all_y" ,scales="free")+
  scale_color_manual(values= c("WTA"="#26547c","Targeted Immunology"="#ef476f","Targeted Pan Cancer"="#ffd166"), name="Gene Panel")+
  mytheme+
  theme(
    legend.position = "bottom",
    axis.text.x = element_text(angle = 45, hjust = 1)  # Rotate x-axis labels 45 degrees
  )+
  xlab("Gene panels")+
  ylab("Predicted proportions")


plt_with_p_val=plt +
   stat_pvalue_manual(
     all_p_values %>% 
     mutate(p.adj.signif=ifelse(p.adj.signif=="****","**",p.adj.signif)) %>% 
     select(group1, group2, p.adj.signif, cell_type, Deconvolution_tool)%>% 
     dplyr::rename("Deconvolution_type"="Deconvolution_tool") %>% 
     mutate(y.position = case_when(group1=="Targeted Immunology" & group2=="Targeted Pan Cancer"~0.8,
                                   group1=="Targeted Immunology" & group2=="WTA"~0.9,
                                   group1=="Targeted Pan Cancer" & group2=="WTA"~1)),  # or assign real y-positions
     label = "p.adj.signif",
     xmin = "group1",
     xmax = "group2",
     y.position = "y.position",
     tip.length = 0.03,
     inherit.aes = FALSE
   )
